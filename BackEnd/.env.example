# Copy this file to .env and fill in real values. Never commit .env.

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_STR=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/omishgo

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=30d

# Cloudinary (product photo uploads — see src/modules/upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS: comma-separated list of allowed browser origins (the AdminWeb panel,
# any other web client). Leave unset in local dev to allow all origins.
# Must be set in production — the app will reject browser requests
# otherwise. Example:
# CORS_ORIGINS=https://admin.omishgo.example,http://localhost:5173
CORS_ORIGINS=

# Admin seeding (scripts/seed.js — see BackEnd/scripts/seed.js).
# Sets up the Farmers' Union admin account(s) before the pilot. The MVP
# doc recommends a primary + backup admin; the second is optional.
SEED_ADMIN_NAME=OmishGo Admin
SEED_ADMIN_PHONE=
SEED_ADMIN_PIN=
SEED_ADMIN2_NAME=OmishGo Admin (Backup)
SEED_ADMIN2_PHONE=
SEED_ADMIN2_PIN=
