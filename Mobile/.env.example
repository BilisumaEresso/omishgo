# OmishGo Mobile App Configuration
# Copy this to Mobile/.env (gitignored) and uncomment the line that matches
# your setup. Leave EXPO_PUBLIC_API_URL unset entirely to fall back to the
# deployed production backend (constants/api.js) — the safe default if
# you're not running a local backend.

# For iOS Simulator (localhost):
# EXPO_PUBLIC_API_URL=http://localhost:5000

# For Android Emulator (use 10.0.2.2 to reach your host machine):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000

# For a physical device on the same Wi-Fi as your dev machine
# (find your IP: 'ipconfig' on Windows, 'ifconfig'/'ip addr' on Mac/Linux):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:5000

# Environment
EXPO_PUBLIC_ENV=development
