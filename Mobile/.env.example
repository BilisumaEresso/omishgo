# OmishGo Mobile App Configuration

# API Configuration
# Update these based on your environment:

# For iOS Simulator (localhost):
# EXPO_PUBLIC_API_URL=http://localhost:5000

# For Android Emulator (use 10.0.2.2 to reach host machine):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000

# For Physical Device (replace with your PC/Mac IP):
# First, find your IP: run 'ipconfig' (Windows) or 'ifconfig' (Mac)
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:5000

# Default (localhost for iOS Simulator):
EXPO_PUBLIC_API_URL=http://localhost:5000

# Environment
EXPO_PUBLIC_ENV=development
