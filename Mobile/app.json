{
  "expo": {
    "name": "OmishGo",
    "slug": "omishgo",
    "description": "Connecting Ethiopian farmers directly with buyers.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bilisuma.omishgo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.bilisuma.omishgo"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "OmishGo needs access to your photos so you can add pictures to your product listings.",
          "cameraPermission": "OmishGo needs access to your camera so you can take a picture of your product to list it."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3f79c698-20e2-4cb2-9396-bae293863bd6"
      }
    }
  }
}
